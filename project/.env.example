# Langfuse Observability (optional)
# Set LANGFUSE_ENABLED=true and provide your API keys to enable tracing.
# Get your keys from https://cloud.langfuse.com or your self-hosted instance.
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=http://localhost:3000

# Image rumor detection (optional overrides)
IMAGE_CAPTION_MODEL=Salesforce/blip-image-captioning-base
IMAGE_CAPTION_MAX_NEW_TOKENS=80
PADDLEOCR_LANG=ch
