# Langfuse Observability (optional)
# Set LANGFUSE_ENABLED=true and provide your API keys to enable tracing.
# Get your keys from https://cloud.langfuse.com or your self-hosted instance.
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=http://localhost:3000

# LLM provider
# Default provider is Qwen through DashScope's OpenAI-compatible API.
# Do not commit real API keys.
LLM_PROVIDER=qwen
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=
RAG_FORCE_RETRIEVAL_FALLBACK=false

# Optional Ollama fallback
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=granite4.1:8b
# OLLAMA_HOST=http://127.0.0.1:11434

# Web server
RAG_UI_MODE=html
RAG_SERVER_NAME=127.0.0.1
RAG_SERVER_PORT=7860
RAG_AUTH_USERNAME=
RAG_AUTH_PASSWORD=

# Image rumor detection (optional overrides)
IMAGE_CAPTION_MODEL=Salesforce/blip-image-captioning-base
IMAGE_CAPTION_MAX_NEW_TOKENS=80
PADDLEOCR_LANG=ch
